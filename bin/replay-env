#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ -x "$ROOT/target/release/replay-env" ]; then
  exec "$ROOT/target/release/replay-env" "$@"
fi

if [ -x "$ROOT/target/debug/replay-env" ]; then
  exec "$ROOT/target/debug/replay-env" "$@"
fi

exec cargo run --quiet --manifest-path "$ROOT/Cargo.toml" -- "$@"
